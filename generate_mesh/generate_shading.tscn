[gd_scene load_steps=4 format=3 uid="uid://52ixd4kddggs"]

[ext_resource type="ArrayMesh" uid="uid://cmnflqt2m28hy" path="res://generate_mesh/human_unshaded.res" id="1_i23o3"]
[ext_resource type="ArrayMesh" uid="uid://btx1ccsb15vgf" path="res://generate_mesh/human_shaded.res" id="3_3mpt7"]

[sub_resource type="GDScript" id="GDScript_kec1h"]
script/source = "extends Node3D

var new_mesh = ArrayMesh.new()
var blend_shapes = []
var mesh_arrays = []
var ST = SurfaceTool.new()

func _ready():

	new_mesh.set_blend_shape_mode(Mesh.BLEND_SHAPE_MODE_NORMALIZED)
	make_basis()
	for bs_index in $Unshaded_Human.get_blend_shape_count():
		process_shape_key(bs_index)
	new_mesh.add_surface_from_arrays(Mesh.PRIMITIVE_TRIANGLES,mesh_arrays,blend_shapes)
	ResourceSaver.save(new_mesh,\"res://generate_mesh/shaded_human.res\")
	
func make_basis():
	var surface_arrays = $Unshaded_Human.mesh.surface_get_arrays(0)
	ST.clear()
	ST.create_from($Unshaded_Human.mesh,0)
	ST.generate_normals()
	ST.generate_tangents()
	mesh_arrays = ST.commit_to_arrays()
	ST.clear()

func process_shape_key(bs_index):
	var bs_name = $Unshaded_Human.mesh.get_blend_shape_name(bs_index)
	ST.create_from_blend_shape($Unshaded_Human.mesh,0,bs_name)
	ST.generate_normals()
	ST.generate_tangents()
#	ST.commit(new_mesh)
	var commit_array = ST.commit_to_arrays()
	new_mesh.add_blend_shape(bs_name)
	var curr_bs = []
	curr_bs.resize(Mesh.ARRAY_MAX)
	curr_bs[Mesh.ARRAY_VERTEX] = commit_array[Mesh.ARRAY_VERTEX]
	curr_bs[Mesh.ARRAY_NORMAL] = commit_array[Mesh.ARRAY_NORMAL]
	curr_bs[Mesh.ARRAY_TANGENT] = commit_array[Mesh.ARRAY_TANGENT]
	#print(commit_array[Mesh.ARRAY_VERTEX].size())
	blend_shapes.append(curr_bs)
	ST.clear()
"

